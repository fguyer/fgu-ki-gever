# --- Docker Compose ---
COMPOSE_PROJECT_NAME=fgu-ki-gever
COMPOSE_FILE=docker-compose.yml

# --- Django / Backend ---
DJANGO_SERVICE=backend
DJANGO_MIGRATE_CMD=python manage.py migrate --noinput
DJANGO_COLLECTSTATIC_CMD=python manage.py collectstatic --noinput
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=YOUR_SERVER_IP,YOUR_DOMAIN
DJANGO_CSRF_TRUSTED_ORIGINS=http://YOUR_SERVER_IP,https://YOUR_DOMAIN

# --- Frontend ---
VITE_API_BASE_URL=/api

# --- Database (for app + backup script) ---
DB_SERVICE=postgres
DB_NAME=gever
DB_USER=gever
DB_PASSWORD=replace-with-a-strong-password
DB_HOST=postgres
DB_PORT=5432
POSTGRES_DB=gever
POSTGRES_USER=gever
POSTGRES_PASSWORD=replace-with-a-strong-password

# --- Backup ---
BACKUP_DIR=./backups
